# =============================================================================
# ISSO Donation Kiosk - Environment Template
# =============================================================================
# Copy this file to .env and fill in values. NEVER commit .env to Git.
# See SECURITY.md for credential rotation instructions after a leak.
# =============================================================================

# --- Database (REQUIRED) ---
# PostgreSQL connection string. Prefer DATABASE_PUBLIC_URL on Railway.
DATABASE_URL=postgresql://user:password@host:port/database
# DATABASE_PUBLIC_URL=postgresql://user:password@host:port/database
# DATABASE_PRIVATE_URL=postgresql://user:password@internal-host:5432/database

# --- Auth (REQUIRED) ---
JWT_SECRET=your-secure-random-string-min-32-chars

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Gmail (for receipt emails) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# --- Google Places (address autocomplete) ---
GOOGLE_PLACES_API_KEY=

# --- CORS / Frontend ---
CORS_ORIGIN=http://localhost:3000
ADMIN_WEB_URL=http://localhost:3000

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Scripts (create-user, verify-user, etc.) ---
# USER_EMAIL=admin@example.com
# USER_PASSWORD=your-secure-password
# USER_NAME=Admin User
# USER_ROLE=MASTER_ADMIN
